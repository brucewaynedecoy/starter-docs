{
  "name": "starter-docs",
  "version": "0.1.0",
  "description": "Drop-in documentation structure, templates, and AI agent instructions with an NPX installer.",
  "type": "module",
  "bin": {
    "starter-docs": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "AGENTS.md",
    "CLAUDE.md",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "validate:defaults": "vitest run tests/consistency.test.ts",
    "smoke:pack": "node scripts/smoke-pack.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@clack/core": "^1.1.0",
    "@clack/prompts": "^1.1.0"
  }
}
